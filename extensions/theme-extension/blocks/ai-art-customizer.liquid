{% comment %}
  AppAI Customizer Block
  ─────────────────────
  Add this block to the template for your /pages/appai-customize page.
  It renders a self-contained AI Art customizer: pick a product → generate art → preview → add to cart.

  To set up:
  1. In Shopify Admin → Online Store → Pages, create a page with handle "appai-customize".
  2. In the page template editor (or Customize), add this "AI Art Customizer" block to the page.
  3. Fill in the "App URL" setting with your Railway app URL (e.g. https://appai-pod-production.up.railway.app).
{% endcomment %}

{% assign app_url = block.settings.app_url | default: '' %}
{% assign shop_domain = shop.permanent_domain %}

{% comment %} Pass config to JS via a data attribute on the root element {% endcomment %}
<div
  id="appai-customizer-root"
  data-shop="{{ shop_domain | escape }}"
  data-app-url="{{ app_url | escape }}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-design-id="{{ request.query | default: '' }}"
  style="font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;"
></div>

{% comment %}
  Design ID from query param ?design_id=... is read by JS via URLSearchParams
  (Liquid doesn't expose query params directly in all themes, so JS handles it).
{% endcomment %}

<script src="{{ 'appai-customizer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "AI Art Customizer",
  "target": "section",
  "settings": [
    {
      "type": "url",
      "id": "app_url",
      "label": "App URL",
      "info": "Your AppAI Railway app URL (e.g. https://appai-pod-production.up.railway.app). Leave blank to auto-detect."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create Your Custom Design"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Describe your vision and we'll generate a unique piece of art, just for you."
    }
  ]
}
{% endschema %}
